// CreativeFlow AI — Prisma schema
// Multi-tenant (shared DB / shared schema). Isolation key: organizationId.

generator client {
  provider = "prisma-client-js"
}

datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// ─────────────────────────────────────────────────────────────
// Enums
// ─────────────────────────────────────────────────────────────

enum Role {
  SUPER_ADMIN
  ORG_ADMIN
  CREATIVE_MANAGER
  DESIGNER
  REQUESTER
}

enum RequestType {
  BANNER
  SOCIAL_MEDIA
  VIDEO
  LANDING_PAGE
  PRESENTATION
  EMAIL_CAMPAIGN
  OTHER
}

enum Priority {
  LOW
  MEDIUM
  HIGH
  CRITICAL
}

enum RequestStatus {
  DRAFT
  SUBMITTED
  ASSIGNED
  IN_PROGRESS
  REVIEW
  CHANGES_REQUESTED
  APPROVED
  COMPLETED
  CANCELLED
}

enum AssetStatus {
  PENDING_REVIEW
  APPROVED
  REJECTED
}

// ─────────────────────────────────────────────────────────────
// Identity & Access
// ─────────────────────────────────────────────────────────────

model Organization {
  id        String   @id @default(uuid())
  name      String
  slug      String   @unique
  plan      String   @default("free")
  isActive  Boolean  @default(true)
  createdAt DateTime @default(now())
  updatedAt DateTime @updatedAt

  users     User[]
  projects  Project[]
  requests  CreativeRequest[]
  workflows Workflow[]
  auditLogs AuditLog[]
  assets    Asset[]
  comments  Comment[]

  @@map("organizations")
}

model User {
  id             String   @id @default(uuid())
  organizationId String
  email          String
  passwordHash   String
  firstName      String
  lastName       String
  role           Role     @default(REQUESTER)
  isActive       Boolean  @default(true)
  lastLoginAt    DateTime?
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization     Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  refreshTokens    RefreshToken[]
  createdRequests  CreativeRequest[] @relation("RequestRequester")
  assignedRequests CreativeRequest[] @relation("RequestAssignee")
  managedProjects  Project[]         @relation("ProjectOwner")
  statusChanges    RequestStatusHistory[]
  auditLogs        AuditLog[]
  uploadedAssets   Asset[]           @relation("AssetUploader")
  reviewedAssets   Asset[]           @relation("AssetReviewer")
  uploadedVersions AssetVersion[]    @relation("VersionUploader")
  comments         Comment[]         @relation("CommentAuthor")
  commentMentions  CommentMention[]  @relation("CommentMentionUser")

  @@unique([organizationId, email])
  @@index([organizationId])
  @@map("users")
}

model RefreshToken {
  id        String   @id @default(uuid())
  userId    String
  tokenHash String
  expiresAt DateTime
  revokedAt DateTime?
  createdAt DateTime @default(now())

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@map("refresh_tokens")
}

// ─────────────────────────────────────────────────────────────
// Work Management
// ─────────────────────────────────────────────────────────────

model Project {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  ownerId        String?
  isArchived     Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization      @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  owner        User?             @relation("ProjectOwner", fields: [ownerId], references: [id], onDelete: SetNull)
  requests     CreativeRequest[]

  @@index([organizationId])
  @@map("projects")
}

model Workflow {
  id             String   @id @default(uuid())
  organizationId String
  name           String
  description    String?
  isDefault      Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization   @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  steps        WorkflowStep[]

  @@index([organizationId])
  @@map("workflows")
}

model WorkflowStep {
  id         String        @id @default(uuid())
  workflowId String
  name       String
  status     RequestStatus
  order      Int
  isApproval Boolean       @default(false)

  workflow Workflow @relation(fields: [workflowId], references: [id], onDelete: Cascade)

  @@unique([workflowId, order])
  @@map("workflow_steps")
}

model CreativeRequest {
  id             String        @id @default(uuid())
  organizationId String
  projectId      String?
  title          String
  description    String?
  type           RequestType   @default(OTHER)
  priority       Priority      @default(MEDIUM)
  status         RequestStatus @default(DRAFT)
  campaign       String?
  department     String?
  dueDate        DateTime?
  requesterId    String
  assigneeId     String?
  completedAt    DateTime?
  createdAt      DateTime      @default(now())
  updatedAt      DateTime      @updatedAt

  // AI-generated metadata (populated by the Gemini module).
  aiSummary            String?
  aiAcceptanceCriteria Json?
  aiSuggestedType      RequestType?
  aiSuggestedPriority  Priority?
  aiConfidence         Float?
  aiEnrichedAt         DateTime?

  organization  Organization           @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  project       Project?               @relation(fields: [projectId], references: [id], onDelete: SetNull)
  requester     User                   @relation("RequestRequester", fields: [requesterId], references: [id])
  assignee      User?                  @relation("RequestAssignee", fields: [assigneeId], references: [id], onDelete: SetNull)
  statusHistory RequestStatusHistory[]
  assets        Asset[]
  comments      Comment[]

  @@index([organizationId])
  @@index([organizationId, status])
  @@index([assigneeId])
  @@map("creative_requests")
}

model RequestStatusHistory {
  id         String        @id @default(uuid())
  requestId  String
  fromStatus RequestStatus?
  toStatus   RequestStatus
  changedById String?
  note       String?
  createdAt  DateTime      @default(now())

  request   CreativeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  changedBy User?           @relation(fields: [changedById], references: [id], onDelete: SetNull)

  @@index([requestId])
  @@map("request_status_history")
}

// ─────────────────────────────────────────────────────────────
// System
// ─────────────────────────────────────────────────────────────

model AuditLog {
  id             String   @id @default(uuid())
  organizationId String
  userId         String?
  action         String
  resource       String
  resourceId     String?
  metadata       Json?
  ipAddress      String?
  createdAt      DateTime @default(now())

  organization Organization @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  user         User?        @relation(fields: [userId], references: [id], onDelete: SetNull)

  @@index([organizationId])
  @@map("audit_logs")
}

// ─────────────────────────────────────────────────────────────
// Assets & Collaboration
// ─────────────────────────────────────────────────────────────

model Asset {
  id             String      @id @default(uuid())
  organizationId String
  requestId      String
  name           String
  status         AssetStatus @default(PENDING_REVIEW)
  currentVersion Int         @default(1)
  uploadedById   String
  reviewedById   String?
  reviewedAt     DateTime?
  reviewNote     String?
  aiTags         Json?
  createdAt      DateTime    @default(now())
  updatedAt      DateTime    @updatedAt

  organization Organization    @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  request      CreativeRequest @relation(fields: [requestId], references: [id], onDelete: Cascade)
  uploadedBy   User            @relation("AssetUploader", fields: [uploadedById], references: [id])
  reviewedBy   User?           @relation("AssetReviewer", fields: [reviewedById], references: [id], onDelete: SetNull)
  versions     AssetVersion[]

  @@index([organizationId])
  @@index([requestId])
  @@map("assets")
}

model AssetVersion {
  id           String   @id @default(uuid())
  assetId      String
  version      Int
  fileName     String
  storageKey   String
  mimeType     String
  size         Int
  checksum     String?
  notes        String?
  uploadedById String
  createdAt    DateTime @default(now())

  asset      Asset @relation(fields: [assetId], references: [id], onDelete: Cascade)
  uploadedBy User  @relation("VersionUploader", fields: [uploadedById], references: [id])

  @@unique([assetId, version])
  @@index([assetId])
  @@map("asset_versions")
}

model Comment {
  id             String   @id @default(uuid())
  organizationId String
  requestId      String
  authorId       String
  parentId       String?
  body           String
  isEdited       Boolean  @default(false)
  createdAt      DateTime @default(now())
  updatedAt      DateTime @updatedAt

  organization Organization     @relation(fields: [organizationId], references: [id], onDelete: Cascade)
  request      CreativeRequest  @relation(fields: [requestId], references: [id], onDelete: Cascade)
  author       User             @relation("CommentAuthor", fields: [authorId], references: [id])
  parent       Comment?         @relation("CommentThread", fields: [parentId], references: [id], onDelete: Cascade)
  replies      Comment[]        @relation("CommentThread")
  mentions     CommentMention[]

  @@index([organizationId])
  @@index([requestId])
  @@index([parentId])
  @@map("comments")
}

model CommentMention {
  id        String   @id @default(uuid())
  commentId String
  userId    String
  createdAt DateTime @default(now())

  comment Comment @relation(fields: [commentId], references: [id], onDelete: Cascade)
  user    User    @relation("CommentMentionUser", fields: [userId], references: [id], onDelete: Cascade)

  @@unique([commentId, userId])
  @@index([userId])
  @@map("comment_mentions")
}
