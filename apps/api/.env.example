# ── Application ───────────────────────────────────────────────
NODE_ENV=development
PORT=4000
API_PREFIX=api/v1
CORS_ORIGIN=http://localhost:3000

# ── Database (PostgreSQL) ─────────────────────────────────────
DATABASE_URL="postgresql://creativeflow:creativeflow@localhost:5432/creativeflow?schema=public"

# ── Redis ─────────────────────────────────────────────────────
REDIS_URL=redis://localhost:6379

# ── JWT Auth ──────────────────────────────────────────────────
JWT_ACCESS_SECRET=change-me-access-secret
JWT_ACCESS_TTL=900s
JWT_REFRESH_SECRET=change-me-refresh-secret
JWT_REFRESH_TTL=7d

# ── Rate limiting ─────────────────────────────────────────────
THROTTLE_TTL=60
THROTTLE_LIMIT=120

# ── Asset storage ─────────────────────────────────────────────
# driver: "local" (disk) or "gcs" (Google Cloud Storage)
STORAGE_DRIVER=local
STORAGE_LOCAL_DIR=storage/uploads
STORAGE_MAX_FILE_SIZE_MB=25
GCS_BUCKET=

# ── Gemini AI (optional) ──────────────────────────────────────
# Leave GEMINI_API_KEY blank to run AI endpoints in heuristic fallback mode.
GEMINI_API_KEY=
GEMINI_MODEL=gemini-1.5-flash
